{
  "manifest_version": 2,
  "name": "PhotoShow",
  "description": "Show images in high-resolution on mouse hover.",
  "version": "4.85.0",
  "default_locale": "en",
  "icons": {
    "16": "resources/icon16.png",
    "32": "resources/icon32.png",
    "48": "resources/icon48.png",
    "64": "resources/icon64.png",
    "128": "resources/icon128.png"
  },
  "background": {
    "scripts": ["background/background.js"],
    "persistent": true
  },
  "browser_action": {
    "default_icon": {
      "16": "resources/icon16.png",
      "32": "resources/icon32.png"
    },
    "default_title": "PhotoShow",
    "default_popup": "popup/popup.html"
  },
  "content_scripts": [
    {
      "matches": ["*://*/*"],
      "js": ["content/sites-loader.js", "content/content.js"],
      "css": ["content/common.css"],
      "run_at": "document_end",
      "all_frames": true
    }
  ],
  "web_accessible_resources": [
    "content/*",
    "resources/*",
    "sites/*"
  ],
  "permissions": [
    "storage",
    "*://*/*"
  ]
}